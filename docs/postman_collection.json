{
  "info": {
    "name": "Pet Family API",
    "description": "Coleção de endpoints da Pet Family API - Challenge CLYVO VET 2026",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Tutores",
      "item": [
        {
          "name": "POST - Cadastrar Tutor",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/tutores", "host": ["{{baseUrl}}"], "path": ["tutores"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Carlos Souza\",\n  \"email\": \"carlos@email.com\",\n  \"telefone\": \"(11) 98765-4321\"\n}"
            }
          }
        },
        {
          "name": "GET - Listar Tutores",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/tutores?page=0&size=10&sort=nome,asc", "host": ["{{baseUrl}}"], "path": ["tutores"], "query": [{"key": "page", "value": "0"}, {"key": "size", "value": "10"}, {"key": "sort", "value": "nome,asc"}]}
          }
        },
        {
          "name": "GET - Filtrar Tutor por Nome",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/tutores?nome=Pedro", "host": ["{{baseUrl}}"], "path": ["tutores"], "query": [{"key": "nome", "value": "Pedro"}]}
          }
        },
        {
          "name": "GET - Buscar Tutor por ID",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/tutores/1", "host": ["{{baseUrl}}"], "path": ["tutores", "1"]}
          }
        },
        {
          "name": "PUT - Atualizar Tutor",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/tutores/1", "host": ["{{baseUrl}}"], "path": ["tutores", "1"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Carlos Souza Jr.\",\n  \"email\": \"carlos.jr@email.com\",\n  \"telefone\": \"(11) 91234-5678\"\n}"
            }
          }
        },
        {
          "name": "DELETE - Remover Tutor",
          "request": {
            "method": "DELETE",
            "url": {"raw": "{{baseUrl}}/tutores/1", "host": ["{{baseUrl}}"], "path": ["tutores", "1"]}
          }
        }
      ]
    },
